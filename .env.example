# Copy this file to .env and fill in the values you have. .env is
# gitignored - never commit real keys.

# Free API key from sam.gov (profile > API Keys). Requires a SAM.gov
# account, which goes through login.gov identity verification - see the
# README's "Enabling sam.gov" section. Optional: the scraper runs fine
# without it, sam.gov just gets skipped.
SAM_GOV_API_KEY=
